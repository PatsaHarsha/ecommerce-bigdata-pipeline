# ================================================================
# Z5008 Big Data Lab — Environment Variables
# Copy this file to .env before running docker-compose up
# ================================================================

# ---- MinIO (S3-compatible object storage) ----
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# ---- PostgreSQL ----
POSTGRES_USER=
POSTGRES_PASSWORD=

# ---- JupyterLab ----
JUPYTER_TOKEN=

# ---- Grafana ----
GRAFANA_PASSWORD=

# ---- Spark ----
SPARK_WORKER_MEMORY=
SPARK_WORKER_CORES=

# ---- MLflow ----
MLFLOW_TRACKING_URI=
